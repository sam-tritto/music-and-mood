# =============================================================================
# Cultural Misery Index — API Keys
# Copy this file to .env and fill in your real keys.
# =============================================================================

# Google Gemini (AI Studio) — https://aistudio.google.com/apikey
# Used for: lyric embeddings (gemini-embedding-001) and narrative generation (gemini-3.5-flash)
GOOGLE_API_KEY=your_google_api_key_here

# Genius Lyrics — https://genius.com/api-clients
# Used for: fetching full song lyrics
GENIUS_ACCESS_TOKEN=your_genius_access_token_here

# FRED (Federal Reserve Economic Data) — https://fred.stlouisfed.org/docs/api/api_key.html
# Used for: unemployment rate (UNRATE) and CPI (CPIAUCSL) for Misery Index
FRED_API_KEY=your_fred_api_key_here

# Kaggle (optional, for programmatic dataset download) — https://www.kaggle.com/settings
# Place your kaggle.json at ~/.kaggle/kaggle.json OR set these:
# KAGGLE_USERNAME=your_kaggle_username
# KAGGLE_KEY=your_kaggle_api_key
